# ⚠️ NEVER commit the actual .env file to Git!
# Copy this file to .env and fill in actual values

# Server Configuration
NODE_ENV=production
PORT=8000

# Database
MONGODB_URI=your_mongodb_connection_string

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# Google Gemini AI
# ⚠️ CRITICAL: Never expose this in client code or error messages
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Frontend URL
FRONTEND_URL=https://your-frontend-domain.com

# Email Configuration (for notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# File Upload Settings
MAX_FILE_SIZE=10485760

# Backend Public URL (for document file paths)
BACKEND_PUBLIC_URL=https://ai-learning-platform-c2jg.onrender.com
PUBLIC_BASE_URL=https://ai-learning-platform-c2jg.onrender.com

# Security
CORS_ORIGINS=https://your-frontend-domain.com,https://another-domain.com
